# Base de datos local (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# OpenAI — obligatorio para generar publicaciones con Design Engine
# Crea tu key en https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Modelos opcionales
# OPENAI_CAMPAIGN_MODEL="gpt-4o"
# OPENAI_IMAGE_MODEL="gpt-image-1-mini"
# OPENAI_AD_IMAGE_MODEL="gpt-image-1"

# URL pública de la app (requerida para publicar en Instagram)
# APP_PUBLIC_URL="https://tu-dominio.com"

# Meta / Facebook / Instagram (OAuth por tienda o token legacy)
# META_APP_ID=""
# META_APP_SECRET=""
# META_ACCESS_TOKEN=""
# META_PAGE_ID=""
# META_INSTAGRAM_ACCOUNT_ID=""

# Sesión JWT
# SESSION_SECRET="cambia-esto-en-produccion"

# Clave para ver el sitio público (vacío = sin proteción / solo local)
# En el VPS el deploy la configura automáticamente.
# SITE_ACCESS_PASSWORD="centralmark2026"

